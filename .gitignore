# Secrets — never commit
.env
.env.*.local

# Scratch space — never commit
tmp/
!tmp/.gitkeep

# Legacy reference copy from nopi — not tracked, will be deleted later
oldstuff/perplexport/

# TiddlyWiki build/runtime output
output/
*.html.bak

# Local CodeGraph index (machine-specific)
.codegraph/

# Python
__pycache__/
*.pyc
.pytest_cache/

# Per-chat build artifacts (sidecars + blobs)
drills/
tiddlers/*_[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]*.tid
