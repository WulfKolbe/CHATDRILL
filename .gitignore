# Secrets — never commit
.env
.env.*.local

# Scratch space — never commit
tmp/
!tmp/.gitkeep

# Legacy reference copy from nopi — not tracked, will be deleted later
oldstuff/perplexport/

# TiddlyWiki build/runtime output
output/
*.html.bak

# Local CodeGraph index (machine-specific)
.codegraph/

# Python
__pycache__/
*.pyc
.pytest_cache/

# Per-chat build artifacts (sidecars + blobs)
drill/
# generated chat tiddlers: bibkey = <ProvCode><YYYYMMDD>_… (an 8-digit date)
wiki/tiddlers/*[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]_*.tid

# generated template tiddlers
wiki/tiddlers/CODE.tid
wiki/tiddlers/FO.tid
wiki/tiddlers/EQ.tid
wiki/tiddlers/URL.tid
wiki/tiddlers/CIT.tid

# raw input conversation files (large; not tracked)
raw/
!raw/.gitkeep
