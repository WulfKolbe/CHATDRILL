latex: \mathbb{E}\left(||\bm{x^{(l)}}||^2_2 ~\bigg|~ ||\bm{x^{(l-1)}}||^2_2 \right) = \sum^{n_l}_{i=1}\mathbb{E}\left( \left(x^{(l)}_i\right)^2 ~\bigg|~ ||\bm{x^{(l-1)}}||^2_2 \right) = \frac{n_l}{2} \left(\sigma^2_{w,l} ||\bm{x^{(l-1)}}||^2 + \sigma^2_{b,l} \right).
latex_original: \mathbb{E}\left(||\bm{x^{(l)}}||^2_2 ~\bigg|~ ||\bm{x^{(l-1)}}||^2_2 \right) = \sum^{n_l}_{i=1}\mathbb{E}\left( \left(x^{(l)}_i\right)^2 ~\bigg|~ ||\bm{x^{(l-1)}}||^2_2 \right) = \frac{n_l}{2} \left(\sigma^2_{w,l} ||\bm{x^{(l-1)}}||^2 + \sigma^2_{b,l} \right).
