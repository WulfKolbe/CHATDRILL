latex: \begin{aligned} \mathbb{E}\left(||\bm{f(x_0)}||^2_2 \right) &= \mathbb{E}\left(\mathbb{E}\left(||\bm{x^{(L)}}||^2_2 ~\bigg|~ ||\bm{x^{(1)}}||^2_2 \right)\right) \\ &= \mathbb{E}\left(\mathbb{E}\left(\mathbb{E}\left(||\bm{x^{(L)}}||^2_2 ~\bigg|~ ||\bm{x^{(2)}}||^2_2 \right) ~\bigg|~ ||\bm{x^{(1)}}||^2_2 \right)\right) \\ &= \mathbb{E}\left(\mathbb{E}\left(\ldots\mathbb{E}\left(\mathbb{E}\left(||\bm{x^{(L)}}||^2_2 ~\bigg|~ ||\bm{x^{(L-1)}}||^2_2 \right) ~\bigg|~ ||\bm{x^{(L-2)}}||^2_2 \right)\ldots ~\bigg|~ ||\bm{x^{(1)}}||^2_2 \right)\right). \end{aligned}
latex_original: \begin{aligned} \mathbb{E}\left(||\bm{f(x_0)}||^2_2 \right) &= \mathbb{E}\left(\mathbb{E}\left(||\bm{x^{(L)}}||^2_2 ~\bigg|~ ||\bm{x^{(1)}}||^2_2 \right)\right) \\ &= \mathbb{E}\left(\mathbb{E}\left(\mathbb{E}\left(||\bm{x^{(L)}}||^2_2 ~\bigg|~ ||\bm{x^{(2)}}||^2_2 \right) ~\bigg|~ ||\bm{x^{(1)}}||^2_2 \right)\right) \\ &= \mathbb{E}\left(\mathbb{E}\left(\ldots\mathbb{E}\left(\mathbb{E}\left(||\bm{x^{(L)}}||^2_2 ~\bigg|~ ||\bm{x^{(L-1)}}||^2_2 \right) ~\bigg|~ ||\bm{x^{(L-2)}}||^2_2 \right)\ldots ~\bigg|~ ||\bm{x^{(1)}}||^2_2 \right)\right). \end{aligned}
