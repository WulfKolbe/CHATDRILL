latex: \begin{aligned} \mathcal{L}(x; w_+, w_-) =& \int_{-1}^0 (e^{x} - w_-\phi(-x))^2 dx \\ &+ \int_0^1 (e^{x} - w_+ \phi(x))^2 dx \\ =&\int_0^1 e^{-2x} - 2e^{-x}w_-x + w_-^2 x^2 \\ &+ e^{2x}- 2e^x w_+ x + w_+^2x^2 dx \\ =& \left[-0.5e^{-2x} + 2e^{-x}w_- x + 2e^{-x}w_- + \frac{1}{3}w_-^2x^3 \right. \\ &\left. +0.5e^{2x} - 2e^xw_+x + 2e^xw_+ +\frac{1}{3}w_+^2x^3+C\right]_0^1\,. \end{aligned}
latex_original: \begin{aligned} \mathcal{L}(x; w_+, w_-) =& \int_{-1}^0 (e^{x} - w_-\phi(-x))^2 dx \\ &+ \int_0^1 (e^{x} - w_+ \phi(x))^2 dx \\ =&\int_0^1 e^{-2x} - 2e^{-x}w_-x + w_-^2 x^2 \\ &+ e^{2x}- 2e^x w_+ x + w_+^2x^2 dx \\ =& \left[-0.5e^{-2x} + 2e^{-x}w_- x + 2e^{-x}w_- + \frac{1}{3}w_-^2x^3 \right. \\ &\left. +0.5e^{2x} - 2e^xw_+x + 2e^xw_+ +\frac{1}{3}w_+^2x^3+C\right]_0^1\,. \end{aligned}
