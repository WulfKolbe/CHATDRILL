latex: \begin{aligned} x^{(l)}_i & = \phi\left(\sum_j w^{(l)}_{ij} x^{(l-1)}_j + b^{(l)}_i\right) \\ & = \phi\left(\sum_j w^{(l)}_{ij} \phi\left(x^{(l-1)}_j\right) - \sum_j w^{(l)}_{ij} \phi\left(-x^{(l-1)}_j\right) + b^{(l)}_i \phi\left( 1 \right) \right). \end{aligned}
latex_original: \begin{aligned} x^{(l)}_i & = \phi\left(\sum_j w^{(l)}_{ij} x^{(l-1)}_j + b^{(l)}_i\right) \\ & = \phi\left(\sum_j w^{(l)}_{ij} \phi\left(x^{(l-1)}_j\right) - \sum_j w^{(l)}_{ij} \phi\left(-x^{(l-1)}_j\right) + b^{(l)}_i \phi\left( 1 \right) \right). \end{aligned}
