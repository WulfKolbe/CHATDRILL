latex: \begin{split} \mathbb{E}\left(||\bm{f(x_0)}||^2_2 \right) = & ||\mathbf{ x}^{(0)}||^2_2 \left(\prod^L_{l=1}\frac{n_l \sigma^{2}_{w,l}}{2}\right) + \sigma^{2}_{b,L} \frac{n_L}{2} + \left(\sum^{L-1}_{l=1} \sigma^{2}_{b,l} \frac{n_l}{2} \left(\prod^{L}_{k=l+1}\frac{n_k\sigma^{2}_{w,k}}{2}\right)\right). \end{split}
latex_original: \begin{split} \mathbb{E}\left(||\bm{f(x_0)}||^2_2 \right) = & ||\mathbf{ x}^{(0)}||^2_2 \left(\prod^L_{l=1}\frac{n_l \sigma^{2}_{w,l}}{2}\right) + \sigma^{2}_{b,L} \frac{n_L}{2} + \left(\sum^{L-1}_{l=1} \sigma^{2}_{b,l} \frac{n_l}{2} \left(\prod^{L}_{k=l+1}\frac{n_k\sigma^{2}_{w,k}}{2}\right)\right). \end{split}
