# CHATDRILL environment — copy to .env and fill in. .env is gitignored.
# The offline path (load, parse, compile, tiddler export) needs ZERO keys.
# Keys are only required for LLM-assisted passes (speech-act/insight classification).

# --- LLM providers (only those you actually use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=        # Qwen
PERPLEXITY_API_KEY=

# --- Default model for LLM-assisted passes ---
CHATDRILL_LLM_PROVIDER=anthropic
CHATDRILL_LLM_MODEL=claude-opus-4-8

# --- Data sources ---
OPENWEBUI_DB=/home/wkolbe/myopenwebui/webui.db

# --- drillui REPL bridge ---
CHATDRILL_BRIDGE_PORT=8788
